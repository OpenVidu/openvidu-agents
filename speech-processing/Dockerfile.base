# syntax=docker/dockerfile:1
# Base Dockerfile for speech-processing agents

ARG PYTHON_VERSION=3.13
FROM python:${PYTHON_VERSION}-slim AS base

# Keeps Python from buffering stdout and stderr to avoid situations where
# the application crashes without emitting any logs due to buffering.
ENV PYTHONUNBUFFERED=1

# Disable pip version check to speed up builds
ENV PIP_DISABLE_PIP_VERSION_CHECK=1

# Limit the number of glibc malloc arenas. This agent runs all jobs as threads in
# a single long-lived process (JobExecutorType.THREAD), and native STT libraries
# (e.g. Vosk/Kaldi) allocate heavily per recognizer. By default glibc creates up
# to 8*ncores arenas, each retaining its own pool of freed-but-not-returned memory.
# Capping arenas drastically reduces this stranded memory; the application also
# calls malloc_trim() explicitly when jobs finish to return freed pages to the OS.
ENV MALLOC_ARENA_MAX=2

# Create a non-privileged user that the app will run under.
# See https://docs.docker.com/develop/develop-images/dockerfile_best-practices/#user
ARG UID=10001
RUN adduser \
    --disabled-password \
    --gecos "" \
    --home "/app" \
    --shell "/sbin/nologin" \
    --uid "${UID}" \
    appuser

# Install build dependencies required for Python packages with native extensions
# gcc: C compiler needed for building Python packages with C extensions
# g++: C++ compiler needed for building Python packages with C++ extensions
# python3-dev: Python development headers needed for compilation
# We clean up the apt cache after installation to keep the image size down
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    python3-dev \
    git \
    # Missing dependencies for some speech processing libraries
    libglib2.0-0 \
  && rm -rf /var/lib/apt/lists/*

# Create a new directory for our application code
# And set it as the working directory
WORKDIR /app

# Prepare Hugging Face cache configuration
ENV HF_HOME=/app/.cache/huggingface \
    HF_HUB_DISABLE_TELEMETRY=1

# Ensure the Hugging Face cache directory exists before switching users
RUN mkdir -p "$HF_HOME"

# Copy only required application source files into the container
# Note: test files are excluded via .dockerignore
COPY main.py stt_impl.py vad_stt_wrapper.py ./
