{
  "name": "openvidu-agents-e2e-tests",
  "version": "1.0.0",
  "scripts": {
    "test:e2e": "playwright test --project=livecaptions --project=livecaptions-processing-dispatch --project=livecaptions-wrong-license --grep-invert nemotron",
    "test:e2e:memory": "playwright test --project=livecaptions-memory-usage --grep-invert nemotron",
    "test:e2e:gpu": "STT_ACCEL=cuda12 playwright test --project=livecaptions --grep \"sherpa|nemotron\"",
    "test:e2e:memory:gpu": "STT_ACCEL=cuda12 playwright test --project=livecaptions-memory-usage --grep \"sherpa|nemotron\""
  },
  "devDependencies": {
    "@livekit/rtc-node": "^0.13.30",
    "@playwright/test": "^1.61.1",
    "@types/node": "26.1.0",
    "fast-levenshtein": "^3.0.0",
    "livekit-server-sdk": "^2.16.0",
    "playwright-ctrf-json-reporter": "^0.0.29",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
